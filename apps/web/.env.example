# Copy to .env.local and fill in values (or use Infisical paths from root .env.example).

# Server-only - session cookie refresh and server-side auth (not sent to the browser).
SUPABASE_URL=<insert-supabase-url>
SUPABASE_PUBLISHABLE_KEY=<insert-supabase-publishable-key>

# Public - API proxying, SSE, and login redirects.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
