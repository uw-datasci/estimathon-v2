# Route the @uw-datasci scope to the GitHub Packages registry.
# GitHub Packages requires the npm scope to match the GitHub org login.
@uw-datasci:registry=https://npm.pkg.github.com

# Auth token is injected by CI (`actions/setup-node`) or your local shell.
# Locally: export NODE_AUTH_TOKEN=<a GitHub PAT with read:packages> before installing.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
